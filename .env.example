# supabase — get these from: supabase.com/dashboard > project > settings > api
# for local dev: run `supabase status` after `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# supabase production — only needed for deployment
PROD_SUPABASE_URL=
PROD_SUPABASE_ANON_KEY=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# solana
# devnet (free): https://api.devnet.solana.com
# mainnet: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# identity verification — get from persona.com/dashboard
# PERSONA_API_KEY is never used in flutter — only in edge functions
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# ai analysis — either or neither works
# hugging face: huggingface.co/settings/tokens (free account, 30k chars/month)
HUGGINGFACE_API_TOKEN=
# openai: platform.openai.com/api-keys (paid, gpt-4o-mini is very cheap)
OPENAI_API_KEY=

# admin panel (next.js — prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=