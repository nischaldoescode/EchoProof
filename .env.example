# supabase — get these from: supabase.com/dashboard > project > settings > api
# for local dev: run `supabase status` after `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# supabase production — only needed for deployment
PROD_SUPABASE_URL=
PROD_SUPABASE_ANON_KEY=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# solana
# devnet (free): https://api.devnet.solana.com
# mainnet: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_DESTINATION_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# admin panel (next.js — prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=