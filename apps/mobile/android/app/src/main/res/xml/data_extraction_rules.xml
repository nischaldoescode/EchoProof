<?xml version="1.0" encoding="utf-8"?>
<!-- data extraction rules -->
<!--
    data_extraction_rules.xml
    controls what data android auto backup and cloud backup can copy
    for a social/trust app like echoproof we exclude everything sensitive
    auth tokens, session data, and hive boxes must never be backed up
    they contain jwts and user state that should not transfer to other devices
    referenced in androidmanifest.xml via:
    android:dataextractionrules="@xml/data_extraction_rules"
    this file applies to android 12+ (api 31+)
    for older android versions, backup_rules.xml handles this
-->
<data-extraction-rules>

    <cloud-backup>
        <!-- disable cloud backup entirely for security -->
        <!-- auth sessions, supabase tokens, hive db should never be synced -->
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- disable device-to-device transfer too -->
        <!-- user must log in fresh on a new device -->
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>

</data-extraction-rules>