<?xml version="1.0" encoding="utf-8"?>
<!--
    backup_rules.xml
    Controls Auto Backup for Android 11 and below (API 30 and earlier).
    For Android 12+ see data_extraction_rules.xml instead.

    To reference this in AndroidManifest.xml add to <application>:
      android:fullBackupContent="@xml/backup_rules"

    But since your manifest already has android:fullBackupContent="false"
    this file is a safety net — you can add it anyway and switch to
    android:fullBackupContent="@xml/backup_rules" if needed.
-->
<full-backup-content>
    <!-- Exclude everything — auth tokens and sessions must not be backed up -->
    <exclude domain="file"      path="." />
    <exclude domain="database"  path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external"  path="." />
    <exclude domain="root"      path="." />
</full-backup-content>