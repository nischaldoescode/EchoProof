<?xml version="1.0" encoding="utf-8"?>
<!-- launch background -->
<!--
    native splash shown before flutter engine boots
    must match the flutter splashscreen layout exactly
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- background color matches appcolors.softgreen / #f5faf7 -->
    <item>
        <color android:color="#F5FAF7"/>
    </item>
    <!--
    app icon centered replace @drawable/splash with your actual
    logo drawable. the gravity="center" matches flutter's centered layout
-->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash"
            android:tileMode="disabled"/>
    </item>
</layer-list>