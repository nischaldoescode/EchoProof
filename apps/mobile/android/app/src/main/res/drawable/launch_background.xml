<?xml version="1.0" encoding="utf-8"?>
<!-- launch background -->
<!--
    native splash shown before flutter engine boots
    must match the flutter splashscreen layout exactly
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- background color matches the flutter splash -->
    <item>
        <color android:color="#E8F5EE"/>
    </item>
    <!-- android launch mask makes this read closer to the flutter mark -->
    <item
        android:width="96dp"
        android:height="96dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/splash"
            android:tileMode="disabled"/>
    </item>
</layer-list>
