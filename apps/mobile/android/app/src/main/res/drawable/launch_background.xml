<?xml version="1.0" encoding="utf-8"?>
<!-- launch background -->
<!--
    native splash shown before flutter engine boots
    must match the flutter splashscreen layout exactly
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- background color matches the flutter splash -->
    <item>
        <color android:color="#E8F5EE"/>
    </item>
    <!-- logo size matches the flutter splash mark -->
    <item
        android:width="110dp"
        android:height="110dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/splash"
            android:tileMode="disabled"/>
    </item>
</layer-list>
