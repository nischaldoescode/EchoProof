.env
Structure.txt

# =============================================
# echoproof monorepo .gitignore
# =============================================

# environment files — never commit these
.env
.env.production
.env.staging
*.env

# =============================================
# flutter / dart
# =============================================

# build outputs
apps/mobile/build/
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/.packages

# generated files
apps/mobile/**/*.g.dart
apps/mobile/**/*.freezed.dart
apps/mobile/**/*.mocks.dart

# ios
apps/mobile/ios/Flutter/Flutter.framework
apps/mobile/ios/Flutter/Flutter.podspec
apps/mobile/ios/Flutter/.last_build_id
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Runner/GeneratedPluginRegistrant.*
apps/mobile/ios/Runner.xcworkspace/xcshareddata/

# android
apps/mobile/android/.gradle/
apps/mobile/android/captures/
apps/mobile/android/local.properties
apps/mobile/android/key.properties          # signing keys — never commit
apps/mobile/android/app/google-services.json

# macos
apps/mobile/macos/Flutter/GeneratedPluginRegistrant.swift
apps/mobile/macos/Flutter/ephemeral/

# test coverage
apps/mobile/coverage/

# =============================================
# next.js admin
# =============================================

apps/admin/.next/
apps/admin/node_modules/
apps/admin/out/
apps/admin/.env.local
apps/admin/.env.production

# =============================================
# supabase
# =============================================

# local supabase state — regenerated by supabase start
supabase/.branches/
supabase/.temp/

# =============================================
# node / javascript
# =============================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
*.tsbuildinfo

# =============================================
# os files
# =============================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# =============================================
# editors
# =============================================

.vscode/settings.json
.vscode/launch.json
.idea/
*.iml
*.ipr
*.iws
.cursor/

# =============================================
# certificates and secrets
# =============================================

*.pem
*.key
*.p12
*.cer
*.mobileprovision
google-services.json
GoogleService-Info.plist